      "name": "0. INITIAL SETUP (Run First)",
      "description": "One-time setup to create admin user - Run this section first before any other tests",
      "item": [
        {
          "name": "Create Admin User (Run Once - One Time Only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if(pm.response.code === 200 || pm.response.code === 201) {",
                  "    console.log('✓ Admin user created successfully');",
                  "    pm.collectionVariables.set(\"admin_token\", jsonData.token);",
                  "    pm.collectionVariables.set(\"admin_id\", jsonData.userId);",
                  "    pm.collectionVariables.set(\"admin_email\", jsonData.email);",
                  "    console.log('Admin ID: ' + jsonData.userId);",
                  "    console.log('Admin Email: ' + jsonData.email);",
                  "} else if(pm.response.code === 409) {",
                  "    console.log('Admin user already exists - this is fine, continue to login');",
                  "} else {",
                  "    console.log('Response: ' + pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"System Administrator\",\n  \"email\": \"admin@photobooking.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"ADMIN\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:8081/api/auth/register",
              "host": ["http://localhost:8081"],
              "path": ["api", "auth", "register"]
            }
          }
        }
      ]
    },
